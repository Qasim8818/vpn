[Unit]
Description=LocalAgent — Private Local AI Assistant (24/7 Service)
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/localagent
ExecStart=/usr/bin/python3 /opt/localagent/agent_daemon.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target

# INSTALLATION (replace YOUR_USERNAME with your actual Linux username):
#
# 1. sudo mkdir -p /opt/localagent
# 2. sudo cp -r /path/to/localagent/* /opt/localagent/
# 3. sudo cp localagentedit.service /etc/systemd/system/
# 4. sudo systemctl daemon-reload
# 5. sudo systemctl enable localagentedit@YOUR_USERNAME.service
# 6. sudo systemctl start  localagentedit@YOUR_USERNAME.service
# 7. sudo systemctl status localagentedit@YOUR_USERNAME.service
